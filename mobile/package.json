{
  "name": "ai-tutor-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "EXPO_NO_DEPENDENCY_VALIDATION=1 expo start",
    "start:offline": "EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --offline",
    "start:offline:clear": "EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --offline --clear",
    "start:lan": "EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --lan",
    "start:localhost": "EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --localhost",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-camera": "~17.0.10",
    "expo-image-picker": "~17.0.10",
    "expo-secure-store": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19"
  }
}
